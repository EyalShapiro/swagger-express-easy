{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    /* Emit */
    "declaration": true,
    "outDir": "./dist",

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,

    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "swagger-express-easy": ["lib/index.ts"],
      "swagger-express-easy/*": ["lib/*"]
    }
  },
  "include": ["src/**/*.ts", "lib/**/*.ts"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
