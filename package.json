{
  "name": "swagger-express-easy",
  "version": "0.0.1",
  "description": "Auto-generated Swagger documentation using swagger-autogen",
  "license": "MIT",
  "author": "Eyal Shapiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/EyalShapiro/swagger-express-easy.git"
  },
  "bugs": {
    "url": "https://github.com/EyalShapiro/swagger-express-easy/issues"
  },
  "homepage": "https://github.com/EyalShapiro/swagger-express-easy#readme",
  "keywords": [
    "swagger",
    "express",
    "openapi",
    "api",
    "docs",
    "autogen",
    "documentation",
    "rest"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "workspaces": [
    "example/*"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./swagger": {
      "require": "./dist/swagger/index.js",
      "types": "./dist/swagger/index.d.ts"
    },
    "./schemas": {
      "require": "./dist/swagger/schemas.js",
      "types": "./dist/swagger/schemas.d.ts"
    },
    "./routeStore": {
      "require": "./dist/swagger/routeStore/index.js",
      "types": "./dist/swagger/routeStore/index.d.ts"
    }
  },
  "scripts": {
    "test": "jest",
    "build": "npx rimraf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "dev:examples": "npm run dev --prefix example",
    "lint": "eslint lib --fix"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "dependencies": {
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jest-util": "^30.4.1",
    "multer": "^1.4.5-lts.1",
    "swagger-autogen": "^2.23.7",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "multer": "1.4.5-lts.1"
  }
}
